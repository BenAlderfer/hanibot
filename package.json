{
  "name": "rbc-bot",
  "version": "1.2.0",
  "description": "RBC Discord bot",
  "engines": {
    "node": "24.x"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "npx ts-node src/index.ts",
    "compile": "tsc -p .",
    "test": "TS_NODE_PROJECT=tsconfig.test.json TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' mocha --require ts-node/register --extension ts \"test/**/*.spec.ts\" --exit",
    "format": "prettier --ignore-path .prettierignore --write \"**/*.+(js|ts|json)\"",
    "lint": "eslint .",
    "prettier-fix": "prettier --write ."
  },
  "dependencies": {
    "discord.js": "^14.5.0",
    "dotenv": "^17.4.2",
    "lodash": "^4.17.21",
    "ts-node": "^10.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/lodash": "^4.14.191",
    "@types/mocha": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/sinon": "^21.0.1",
    "@types/sinon-chai": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "chai": "^6.2.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "sinon": "^21.1.2",
    "sinon-chai": "^4.0.1",
    "typescript": "^6.0.3"
  }
}
